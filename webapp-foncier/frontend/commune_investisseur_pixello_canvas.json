            {
              "id": "fiche-chiffres",
              "type": "frame",
              "name": "Fiche et chiffres clés",
              "backgroundColor": "#ffffff",
              "borderRadius": 12,
              "padding": 16,
              "children": [
                {
                  "type": "frame",
                  "name": "Fiche identité",
                  "children": [
                    { "type": "text", "content": "Lyon — 69001", "fontSize": 14, "color": "#111827", "fontWeight": "600" },
                    { "type": "text", "content": "Département : Rhône (69) · Région : Auvergne-Rhône-Alpes", "fontSize": 14, "color": "#4b5563" },
                    { "type": "text", "content": "EPCI : Métropole de Lyon (si disponible)", "fontSize": 14, "color": "#4b5563" }
                  ]
                },
                {
                  "type": "frame",
                  "name": "Chiffres clés",
                  "layout": "grid",
                  "columns": "1fr 1fr",
                  "gap": 12,
                  "children": [
                    { "type": "card", "label": "Ventes (période)", "value": "2 847", "accentColor": "#2563eb" },
                    { "type": "card", "label": "Prix médian", "value": "285 000 €", "accentColor": "#2563eb" },
                    { "type": "card", "label": "Loyer médian / m²", "value": "13,20 €", "accentColor": "#2563eb" },
                    { "type": "card", "label": "Ménages avec aide logt", "value": "32 %", "accentColor": "#2563eb" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "section-logement",
      "type": "section",
      "name": "Panorama logement",
      "y": 420,
      "title": "Panorama logement",
      "titleStyle": { "fontSize": 18, "color": "#1e3a5f", "borderBottom": "2px solid #2563eb" },
      "children": [
        {
          "id": "fiscalite",
          "type": "subsection",
          "title": "Fiscalité locale",
          "y": 0,
          "children": [
            {
              "type": "table",
              "name": "Taux fiscaux par année",
              "headers": ["Année", "TFNB", "TFB", "TEOM", "TH"],
              "rows": [
                ["2022", "12,45 %", "22,18 %", "9,12 %", "—"],
                ["2023", "12,52 %", "22,31 %", "9,18 %", "—"],
                ["2024", "12,48 %", "22,25 %", "9,15 %", "—"]
              ],
              "alignRight": ["TFNB", "TFB", "TEOM", "TH"]
            }
          ]
        },
        {
          "id": "vente",
          "type": "subsection",
          "title": "Vente",
          "y": 0,
          "children": [
            {
              "type": "frame",
              "name": "Résumé vente",
              "layout": "flex",
              "flexDirection": "row",
              "gap": 24,
              "children": [
                { "type": "stat", "label": "Ventes", "value": "2 847" },
                { "type": "stat", "label": "Prix médian", "value": "285 000 €" },
                { "type": "stat", "label": "Prix médian / m²", "value": "4 120 €/m²" },
                { "type": "stat", "label": "Surface médiane", "value": "68 m²" },
                { "type": "stat", "label": "Type", "value": "Tous · Appart. · Maison" }
              ]
            },
            {
              "type": "placeholder",
              "name": "Graphique évolution prix",
              "height": 200,
              "backgroundColor": "#f8fafc",
              "border": "1px dashed #d1d5db",
              "content": "Évolution prix médian (€) — courbe par année"
            },
            { "type": "text", "content": "Répartition : Appartement 78 % · Maison 22 %", "fontSize": 14, "color": "#6b7280" }
          ]
        },
        {
          "id": "location",
          "type": "subsection",
          "title": "Location",
          "y": 0,
          "children": [
            {
              "type": "frame",
              "name": "Cartes location",
              "layout": "grid",
              "columns": "repeat(4, 1fr)",
              "gap": 12,
              "children": [
                { "type": "card", "label": "Loyer/m² (appart.)", "value": "13,20 €", "sublabel": "[12,10 – 14,30]", "accentColor": "#059669" },
                { "type": "card", "label": "Loyer/m² (maison)", "value": "10,80 €", "sublabel": "[9,50 – 12,10]", "accentColor": "#059669" },
                { "type": "card", "label": "Part APL", "value": "28 %", "accentColor": "#059669" },
                { "type": "card", "label": "Autre aide logt", "value": "12 %", "accentColor": "#059669" }
              ]
            },
            {
              "type": "placeholder",
              "name": "Graphique évolution loyer",
              "height": 200,
              "backgroundColor": "#f8fafc",
              "border": "1px dashed #d1d5db",
              "content": "Évolution loyer au m² (€) — courbe par année"
            }
          ]
        }
      ]
    },
    {
      "id": "section-population",
      "type": "section",
      "name": "Panorama population",
      "y": 1100,
      "title": "Panorama population",
      "titleStyle": { "fontSize": 18, "color": "#1e3a5f", "borderBottom": "2px solid #2563eb" },
      "children": [
        {
          "type": "frame",
          "name": "Indicateurs RPLs et aides",
          "layout": "grid",
          "columns": "repeat(4, 1fr)",
          "gap": 12,
          "children": [
            { "type": "card", "label": "Logements (RPLs)", "value": "~ 185 000", "accentColor": "#7c3aed" },
            { "type": "card", "label": "Répart. 1–2 pièces", "value": "42 %", "accentColor": "#7c3aed" },
            { "type": "card", "label": "Répart. 3+ pièces", "value": "58 %", "accentColor": "#7c3aed" },
            { "type": "card", "label": "Logts < 1990", "value": "35 %", "accentColor": "#7c3aed" }
          ]
        },
        {
          "type": "frame",
          "name": "À venir",
          "layout": "grid",
          "columns": "1fr 1fr",
          "gap": 16,
          "children": [
            {
              "type": "placeholder",
              "name": "Population",
              "backgroundColor": "#fef3c7",
              "border": "1px dashed #f59e0b",
              "content": "Population — Effectifs, pyramide des âges — données à venir (Insee)"
            },
            {
              "type": "placeholder",
              "name": "Revenus et emploi",
              "backgroundColor": "#fef3c7",
              "border": "1px dashed #f59e0b",
              "content": "Revenus & emploi — Revenu médian, chômage, CSP — données à venir (Insee)"
            }
          ]
        }
      ]
    }
  ],
  "meta": {
    "source": "commune_investisseur_maquette.html",
    "version": "1.0",
    "createdFor": "Pixello"
  }
}
