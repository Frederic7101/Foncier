{
  "$schema": "https://pixello.tech/schema/canvas-v1",
  "name": "Fiche commune investisseur",
  "description": "Page fiche commune pour investisseur immobilier — panorama ville, logement, population",
  "width": 1200,
  "height": 2400,
  "backgroundColor": "#f5f5f7",
  "children": [
    {
      "id": "badge",
      "type": "frame",
      "name": "Badge Maquette",
      "x": 1100,
      "y": 12,
      "width": 88,
      "height": 24,
      "backgroundColor": "#f59e0b",
      "borderRadius": 4,
      "children": [
        { "type": "text", "content": "Maquette — Données fictives", "fontSize": 12, "color": "#ffffff", "fontWeight": "600" }
      ]
    },
    {
      "id": "header",
      "type": "frame",
      "name": "En-tête page",
      "y": 8,
      "width": 1200,
      "height": 40,
      "children": [
        { "type": "text", "content": "Fiche commune investisseur", "fontSize": 24, "color": "#000080", "fontWeight": "700" },
        { "type": "text", "content": "Panorama ville, logement et population", "fontSize": 14, "color": "#4b5563", "y": 32 }
      ]
    },
    {
      "id": "commune-header",
      "type": "frame",
      "name": "Sélection commune",
      "y": 56,
      "width": 1200,
      "height": 72,
      "backgroundColor": "#ffffff",
      "borderRadius": 12,
      "padding": 12,
      "layout": "flex",
      "flexDirection": "row",
      "gap": 16,
      "children": [
        {
          "type": "text",
          "content": "Fiche commune — Lyon (69001)",
          "fontSize": 20,
          "color": "#1e3a5f",
          "fontWeight": "700",
          "flex": 1
        },
        {
          "type": "frame",
          "name": "Selects",
          "layout": "flex",
          "flexDirection": "row",
          "gap": 8,
          "children": [
            { "type": "dropdown", "label": "Région", "options": ["— Région —", "Auvergne-Rhône-Alpes"], "width": 160 },
            { "type": "dropdown", "label": "Département", "options": ["— Département —", "69 Rhône"], "width": 140 },
            { "type": "dropdown", "label": "Commune", "options": ["— Commune —", "Lyon"], "width": 140 }
          ]
        },
        {
          "type": "frame",
          "name": "Période",
          "layout": "flex",
          "flexDirection": "row",
          "gap": 6,
          "children": [
            { "type": "text", "content": "Période", "fontSize": 14, "color": "#4b5563" },
            { "type": "input", "kind": "number", "placeholder": "2020", "width": 56 },
            { "type": "text", "content": "–", "fontSize": 14 },
            { "type": "input", "kind": "number", "placeholder": "2024", "width": 56 }
          ]
        },
        {
          "type": "frame",
          "name": "Nav",
          "layout": "flex",
          "flexDirection": "row",
          "gap": 12,
          "children": [
            { "type": "link", "content": "Recherche par adresse", "url": "recherche_ventes.html", "color": "#2563eb" },
            { "type": "link", "content": "Statistiques par zone", "url": "stats_ventes.html", "color": "#2563eb" }
          ]
        }
      ]
    },
    {
      "id": "section-global",
      "type": "section",
      "name": "Panorama global sur la ville",
      "y": 140,
      "title": "Panorama global sur la ville",
      "titleStyle": { "fontSize": 18, "color": "#1e3a5f", "borderBottom": "2px solid #2563eb" },
      "children": [
        {
          "id": "panorama-global-grid",
          "type": "frame",
          "layout": "grid",
          "columns": "280px 1fr",
          "gap": 16,
          "width": 1200,
          "height": 260,
          "children": [
            {
              "id": "map-placeholder",
              "type": "placeholder",
              "name": "Carte",
              "width": 280,
              "height": 220,
              "backgroundColor": "#e5e7eb",
              "borderRadius": 12,
              "border": "2px dashed #9ca3af",
